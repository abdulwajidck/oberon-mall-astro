}
.greview-arrow.open { transform: rotate(180deg); }
.greview-dropdown {
  position: absolute;
  top: calc(100% + 8px);
  left: 50%;
  transform: translateX(-50%);
  width: 360px;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease, opacity 0.3s ease;
  opacity: 0;
  border-radius: 12px;
  background: rgba(0,0,0,0.85);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255,255,255,0.1);
}
.greview-dropdown.open {
  max-height: 500px;
  opacity: 1;
  overflow-y: auto;
}
.greview-dropdown-inner { padding: 20px; }
.greview-header {
  color: #fff;
  font-size: 1rem;
  margin-bottom: 16px;
