@media (max-width: 480px) {
  .greview-dropdown { width: 300px; left: 0; transform: none; }
}
</style>

<script>
function toggleReviews() {
  const dropdown = document.getElementById('greviewDropdown');
  const arrow = document.getElementById('greviewArrow');
  dropdown.classList.toggle('open');
  arrow.classList.toggle('open');
}
// Close on click outside
document.addEventListener('click', function(e) {
  const widget = document.getElementById('greviewWidget');
  if (widget && !widget.contains(e.target)) {
    document.getElementById('greviewDropdown').classList.remove('open');
    document.getElementById('greviewArrow').classList.remove('open');
  }
});
</script>