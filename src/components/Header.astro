---
import { siteConfig, navLinks } from '../data/stores.ts';

const { pathname } = Astro.url;
---

<!-- Gold Top Promo Bar -->
<div class="header-promo">
  <div class="container">
    <span>Festive season is around the corner! Shop the best deals at up to 85% off on Oberon Mall.</span>
  </div>
</div>

<header class="header">
  <div class="header-inner">
    <a href="/" class="header-logo">
      <img src={siteConfig.logo} alt="Oberon Mall" width="125" height="99" />
    </a>
    <nav class="header-nav" id="nav">
      <ul>
        {navLinks.map(link => {
          const isActive = pathname === link.href || pathname === link.href + '/';
          return (
            <li>
              <a href={link.href} class={isActive ? 'active' : ''}>{link.label}</a>
            </li>
          );
        })}
      </ul>
    </nav>
    <button class="hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<script>
  const hamburger = document.getElementById('hamburger');
  const nav = document.getElementById('nav');
  if (hamburger && nav) {
    hamburger.addEventListener('click', () => nav.classList.toggle('open'));
  }
</script>