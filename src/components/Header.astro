---
import { siteConfig, navLinks } from '../data/stores.ts';

const { pathname } = Astro.url;
---

<header class="header">
  <div class="header-top">
    <a href={siteConfig.phoneLink}>{siteConfig.phone}</a>
  </div>
  <div class="header-main">
    <a href="/" class="header-logo">
      <img src={siteConfig.logo} alt="Oberon Mall" width="125" height="99" />
    </a>
    <nav class="header-nav" id="nav">
      {navLinks.map(link => (
        <a href={link.href} class={pathname === link.href || pathname === link.href + '/' ? 'active' : ''}>{link.label}</a>
      ))}
    </nav>
    <button class="hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<script>
  const hamburger = document.getElementById('hamburger');
  const nav = document.getElementById('nav');
  if (hamburger && nav) {
    hamburger.addEventListener('click', () => nav.classList.toggle('open'));
  }
</script>