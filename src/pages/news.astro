---
import Layout from '../layouts/Layout.astro';
import Newsletter from '../components/Newsletter.astro';
import { newsArticles } from '../data/stores.ts';
---

<Layout title="News - Oberon Mall" description="Keeping you up-to-date with the latest news and events at Oberon Mall.">
  <section class="page-hero">
    <h1>News & Articles</h1>
  </section>

  <section class="section">
    <div class="container">
      <div style="text-align:center;margin-bottom:20px;">
        <form style="max-width:400px;margin:0 auto;display:flex;gap:8px;" onsubmit="return false;">
          <input type="search" placeholder="Search for..." style="flex:1;padding:12px 16px;border:1px solid #d1d5db;border-radius:3px;font-size:1rem;" />
          <button type="submit" class="btn">Search</button>
        </form>
      </div>
      <h2 style="text-transform:uppercase;text-align:center;margin-bottom:30px;">Latest Posts</h2>
      <div class="store-grid">
        {newsArticles.map(article => (
          <article class="news-card">
            <a href={`/news/${article.slug}/`}>
              <img src="https://oberonmall.com/wp-content/uploads/2024/12/2021-12-12.jpg" alt={article.title} />
            </a>
            <div class="news-card-body">
              <div class="news-card-date">{article.date}</div>
              <h3><a href={`/news/${article.slug}/`}>{article.title}</a></h3>
              <p style="color:#737373;font-size:0.95rem;margin:8px 0;">{article.excerpt}</p>
              <a href={`/news/${article.slug}/`} class="read-more">Read More →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Newsletter />
</Layout>