---
import Layout from '../layouts/Layout.astro';
import Newsletter from '../components/Newsletter.astro';
import { newsArticles } from '../data/stores.ts';

const newsImages = [
  'https://oberonmall.com/wp-content/uploads/2024/12/WhatsApp-Image-2024-12-01-at-12.36.37-PM-e1733037009254.jpeg',
  'https://oberonmall.com/wp-content/uploads/2024/12/2148385668.jpg',
  'https://oberonmall.com/wp-content/uploads/2024/12/2300-2.jpg'
];
---

<Layout title="News & Articles - Oberon Mall" description="Keeping you up-to-date with the latest news and events at Oberon Mall.">
  <!-- 1. Page Hero -->
  <section class="page-hero">
    <h1>News & Articles</h1>
  </section>

  <section class="section">
    <div class="container">
      <!-- 2. Search bar -->
      <form class="news-search" onsubmit="return false;">
        <input type="search" placeholder="Search for..." aria-label="Search articles" />
        <button type="submit" class="btn">Search</button>
      </form>

      <!-- 3. LATEST POSTS heading -->
      <div class="section-heading">
        <h2>Latest Posts</h2>
      </div>

      <!-- 4. Three article cards with exact images -->
      <div class="news-grid">
        {newsArticles.map((article, i) => (
          <article class="news-card">
            <a href={`/news/${article.slug}/`} class="news-card-link">
              <img src={newsImages[i]} alt={article.title} loading="lazy" />
              <div class="news-card-body">
                <div class="news-card-date">{article.date}</div>
                <h3>{article.title}</h3>
                <p style="color:#737373;font-size:0.95rem;margin:8px 0;">{article.excerpt}</p>
                <span class="read-more">Read More →</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. Newsletter -->
  <Newsletter />
</Layout>