---
import Layout from '../layouts/Layout.astro';
import Newsletter from '../components/Newsletter.astro';
import { stores } from '../data/stores.ts';
const diningStores = stores.filter(s => s.category === "Food & Beverage");
---

<Layout title="Dining - Oberon Mall" description="Discover dining options at Oberon Mall. From fast food to fine dining, savor flavors that delight your taste buds.">
  <section class="page-hero">
    <h1>Dine Happy, Return Hungry</h1>
  </section>

  <section class="section">
    <div class="container">
      <div class="store-grid">
        {diningStores.map(store => (
          <a href={`/brand/${store.slug}/`} class="store-card" style={`background-image:url(${store.bgImg || store.logo});`}>
            {store.logo && !store.logo.startsWith('data:') && <img src={store.logo} alt={store.name} class="store-card-logo" />}
            <div class="store-card-content">
              <h6>{store.name}</h6>
              {store.hours && <span class="store-hours">Open {store.hours}</span>}
              {store.floor && <span class="store-floor">{store.floor}</span>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="promo-banner" style="background-image:url(https://oberonmall.com/wp-content/uploads/2024/12/2021-12-12.jpg);">
    <div class="promo-banner-content">
      <h2>Savor Flavors That Delight Your Taste Buds</h2>
    </div>
  </section>

  <section class="section" style="background:var(--cream);">
    <div class="container">
      <div style="text-align:center;margin-bottom:40px;">
        <h2 style="text-transform:uppercase;">Get In Touch</h2>
      </div>
      <form class="contact-form" style="margin:0 auto;" onsubmit="return false;">
        <input type="text" placeholder="Name *" required />
        <input type="email" placeholder="Email *" required />
        <input type="tel" placeholder="Phone" />
        <textarea placeholder="Message *" required></textarea>
        <button type="submit" class="btn">Send Message</button>
      </form>
    </div>
  </section>

  <Newsletter />
</Layout>