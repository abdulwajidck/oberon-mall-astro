---
import Layout from '../layouts/Layout.astro';
import Newsletter from '../components/Newsletter.astro';
import { stores } from '../data/stores.ts';

const galleryImages = stores.filter(s => s.bgImg);
---

<Layout title="Gallery - Oberon Mall" description="Explore the visual beauty of Oberon Mall through our gallery.">
  <!-- 1. Page Hero -->
  <section class="page-hero">
    <h1>Gallery</h1>
  </section>

  <!-- 2. Image grid using store background images -->
  <section class="section">
    <div class="container">
      <div class="gallery-grid">
        {galleryImages.map(store => (
          <a href={`/brand/${store.slug}/`} class="gallery-item">
            <img src={store.bgImg} alt={store.name} loading="lazy" />
            <div class="gallery-item-overlay">{store.name}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. Newsletter -->
  <Newsletter />
</Layout>