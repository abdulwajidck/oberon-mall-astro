---
import Layout from '../layouts/Layout.astro';
import Newsletter from '../components/Newsletter.astro';
import { siteConfig } from '../data/stores.ts';
---

<Layout title="Contact - Oberon Mall" description="Contact Oberon Mall. Find our address, phone number, email, and mall timings.">
  <section class="page-hero">
    <h1>Contact</h1>
  </section>

  <section class="section">
    <div class="container" style="display:grid;grid-template-columns:1fr 1fr;gap:60px;">
      <div>
        <img src="https://oberonmall.com/wp-content/uploads/2024/12/2021-12-12.jpg" alt="Oberon Mall" style="border-radius:4px;width:100%;margin-bottom:24px;" />
        <h2 style="text-transform:uppercase;font-size:1.4rem;margin-bottom:16px;">Oberon Mall Contact Information</h2>
        <p style="margin-bottom:12px;"><strong>Address:</strong><br />{siteConfig.address}</p>
        <p style="margin-bottom:12px;"><strong>Phone:</strong><br />Customer Care: <a href={siteConfig.phoneLink}>{siteConfig.phone}</a></p>
        <p style="margin-bottom:12px;"><strong>Email:</strong><br /><a href="mailto:info@oberonmall.com">info@oberonmall.com</a> or <a href="mailto:support@oberonmall.com">support@oberonmall.com</a></p>
        <p style="margin-bottom:12px;"><strong>Hours:</strong><br />Mall Timings: 10:00 AM - 10:00 PM (All Days)</p>
      </div>
      <div>
        <form class="contact-form" onsubmit="return false;">
          <input type="text" placeholder="Name *" required />
          <input type="email" placeholder="Email *" required />
          <input type="tel" placeholder="Phone *" required />
          <input type="text" placeholder="Subject" />
          <textarea placeholder="Message" required></textarea>
          <button type="submit" class="btn">Send Message</button>
        </form>
        <div style="margin-top:24px;border-radius:4px;overflow:hidden;">
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3929.0!2d76.3124!3d10.0224!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTDCsDAxJzIwLjYiTiA3NsKwMTgnNDQuNiJF!5e0!3m2!1sen!2sin!4v0000000000000" width="100%" height="250" style="border:0;" loading="lazy" title="Map"></iframe>
        </div>
      </div>
    </div>
  </section>

  <Newsletter />
</Layout>