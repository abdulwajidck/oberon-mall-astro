---
import Layout from '../layouts/Layout.astro';
import Newsletter from '../components/Newsletter.astro';
import { siteConfig } from '../data/stores.ts';

const oberonImage = 'https://oberonmall.com/wp-content/uploads/2024/12/FINAL-RENDER-2.png';
---

<Layout title="Contact - Oberon Mall" description="Contact Oberon Mall. Find our address, phone number, email, and mall timings.">
  <!-- 1. Page Hero -->
  <section class="page-hero">
    <h1>Contact</h1>
  </section>

  <!-- 2 & 3. Left: image + contact info, Right: form -->
  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <!-- Left: Image + Contact Info -->
        <div>
          <img src={oberonImage} alt="Oberon Mall" class="contact-info-img" loading="lazy" />
          <div class="contact-info-item">
            <h4>Address</h4>
            <p>34, 195 Road, NH Bye Pass, Padivattom, Edappally,<br />Ernakulam, Kochi, Kerala 682024</p>
          </div>
          <div class="contact-info-item">
            <h4>Phone</h4>
            <p>Customer Care: <a href={siteConfig.phoneLink}>{siteConfig.phone}</a></p>
          </div>
          <div class="contact-info-item">
            <h4>Email</h4>
            <p><a href="mailto:info@oberonmall.com">info@oberonmall.com</a> or <a href="mailto:support@oberonmall.com">support@oberonmall.com</a></p>
          </div>
          <div class="contact-info-item">
            <h4>Hours</h4>
            <p>Mall Timings: 10:00 AM - 10:00 PM (All Days)</p>
          </div>
        </div>

        <!-- Right: Contact Form -->
        <div>
          <form class="contact-form" onsubmit="return false;">
            <input type="text" placeholder="Name *" required />
            <input type="email" placeholder="Email *" required />
            <input type="tel" placeholder="Phone *" required />
            <input type="text" placeholder="Subject" />
            <textarea placeholder="Message *" required></textarea>
            <button type="submit" class="btn">Send Message</button>
          </form>
        </div>
      </div>

      <!-- 4. Google Maps embed -->
      <div class="contact-map">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3929.0!2d76.3124!3d10.0224!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTDCsDAxJzIwLjYiTiA3NsKwMTgnNDQuNiJF!5e0!3m2!1sen!2sin!4v0000000000000"
          width="100%"
          height="350"
          style="border:0;"
          loading="lazy"
          title="Oberon Mall Location Map"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- 5. Newsletter -->
  <Newsletter />
</Layout>