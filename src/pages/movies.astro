---
import Layout from '../layouts/Layout.astro';
import Newsletter from '../components/Newsletter.astro';
import { newsArticles } from '../data/stores.ts';
---

<Layout title="PVR Cinemas - Oberon Mall" description="Your ultimate movie destination. Cinematic delights at Oberon Mall with PVR Cinemas.">
  <section class="page-hero">
    <h1>Cinematic Delights At Oberon Mall</h1>
  </section>

  <section class="section">
    <div class="container" style="text-align:center;max-width:800px;margin:0 auto;">
      <h2 style="text-transform:uppercase;">Your Ultimate Movie Destination</h2>
      <p style="margin:20px 0;font-size:1.15rem;color:#737373;">Experience the magic of the big screen at PVR Cinemas, Oberon Mall. With state-of-the-art sound, comfortable seating, and the latest blockbusters, every visit is a cinematic adventure.</p>
      <a href="https://www.pvrcinemas.com" target="_blank" class="btn">Book Tickets</a>
    </div>
  </section>

  <section class="section" style="background:var(--cream);">
    <div class="container">
      <div style="text-align:center;margin-bottom:40px;">
        <h2 style="text-transform:uppercase;">News & Articles</h2>
        <p style="color:#737373;">Keeping you up-to-date with the latest news and events.</p>
      </div>
      <div class="store-grid">
        {newsArticles.map(article => (
          <article class="news-card">
            <a href={`/news/${article.slug}/`}>
              <img src="https://oberonmall.com/wp-content/uploads/2024/12/2021-12-12.jpg" alt={article.title} />
            </a>
            <div class="news-card-body">
              <div class="news-card-date">{article.date}</div>
              <h3><a href={`/news/${article.slug}/`}>{article.title}</a></h3>
              <a href={`/news/${article.slug}/`} class="read-more">Read More →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Newsletter />
</Layout>