---
import Layout from '../layouts/Layout.astro';
import Newsletter from '../components/Newsletter.astro';
import { newsArticles } from '../data/stores.ts';

// Brand logos for marquee (27 logos, duplicated for seamless loop)
const brandLogos = [
  'PVR-01.png', 'PURPLLE-01.png', 'Titan-01.png', 'BASKIN-ROBBINS-01.png',
  'KFC-01.png', 'RELIANCE-RES-Q-01.png', 'CAFE-COFFEE-DAY-01.png', 'RELIANCE-DIGITAL-01.png',
  'BASICS-01.png', 'JOHN-PLAYERS-01.png', 'PLANET-FASHION-01.png', 'TRENDS-FOOTWEAR-01.png',
  'AVANTRA-BY-TRENDS-01.png', 'LENOVO-01.png', 'CHICKING-01.png', 'METHIYADI-01.png',
  'FUJI-FILM-01.png', 'TRENDS-01.png', 'hp-01.png', 'ZIVAME-01.png',
  'FRAGOMEN-01.png', 'Jio-01.png', 'INCUSPAZE-01.png', 'THE-CHOCOLATE-TAP-01.png',
  'JOCKEY-01.png', 'STYLE-UNION-01.png', 'PAYLESS-01.png'
];
const logoBase = 'https://oberonmall.com/wp-content/uploads/2024/12/';
const brandLogosDoubled = [...brandLogos, ...brandLogos];

// News article images (exact from original)
const newsImages = [
  'https://oberonmall.com/wp-content/uploads/2024/12/WhatsApp-Image-2024-12-01-at-12.36.37-PM-e1733037009254.jpeg',
  'https://oberonmall.com/wp-content/uploads/2024/12/2148385668.jpg',
  'https://oberonmall.com/wp-content/uploads/2024/12/2300-2.jpg'
];
---

<Layout>
  <!-- ===== HERO SECTION ===== -->
  <section class="hero">
    <video autoplay muted loop playsinline class="hero-video-desktop">
      <source src="https://oberonmall.com/wp-content/uploads/2024/11/Oberon-Video.mp4" type="video/mp4" />
    </video>
    <video autoplay muted loop playsinline class="hero-video-mobile">
      <source src="https://oberonmall.com/wp-content/uploads/2024/12/oberon-video-Mobile_1-1.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Discover Oberon Mall</h1>
      <a href="/brand/" class="btn btn-hero">See All Stores</a>
    </div>
  </section>

  <!-- ===== DECORATIVE OBERON LOGO DIVIDER ===== -->
  <div class="logo-divider">
    <img src="https://oberonmall.com/wp-content/uploads/2024/11/Screenshot_2024-11-27_at_11.26.14_PM-removebg-preview-e1732730735192.png" alt="Oberon Mall" width="80" height="80" />
  </div>

  <!-- ===== BRAND LOGO MARQUEE ===== -->
  <section class="brand-marquee-section" aria-label="Our Brands">
    <div class="brand-marquee">
      <div class="brand-marquee-track">
        {brandLogosDoubled.map((logo) => (
          <div class="brand-marquee-item">
            <img src={logoBase + logo} alt="Brand logo" width="150" height="60" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FIND IT. LOVE IT. SECTION ===== -->
  <section class="section section--gradient-cream">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">Explore</span>
        <h2>Find It. Love It.</h2>
        <p class="section-sub">Discover luxury, dining, beauty &amp; fun.</p>
      </div>
      <div class="featured-cards">
        <a href="/events/" class="featured-card featured-card--wide">
          <img src="https://oberonmall.com/wp-content/uploads/2024/12/Oberon-Web-Video.gif" alt="Meet Me @OBERON" width="1080" height="540" loading="lazy" />
          <div class="featured-card-overlay">
            <h3>Meet Me @OBERON™</h3>
            <span class="btn-link">Join The Fun →</span>
          </div>
        </a>
        <a href="/brand/purplle/" class="featured-card featured-card--square">
          <img src="https://oberonmall.com/wp-content/uploads/2024/12/IMG_4887-e1733131781398.jpeg" alt="Now Open: Purplle" width="510" height="510" loading="lazy" />
          <div class="featured-card-overlay">
            <h3>Now Open: Purplle</h3>
            <span class="btn-link">See The Details →</span>
          </div>
        </a>
        <a href="/brand/cafe-coffee-day/" class="featured-card featured-card--square">
          <img src="https://oberonmall.com/wp-content/uploads/2024/12/IMG-Final-2.png" alt="Now Open: Cafe Coffee Day" width="510" height="510" loading="lazy" />
          <div class="featured-card-overlay">
            <h3>Now Open: Cafe Coffee Day</h3>
            <span class="btn-link">See The Details →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== MORE TO DISCOVER ===== -->
  <section class="section section--gradient-gold">
    <div class="container">
      <div class="section-heading">
        <h2>More To Discover</h2>
      </div>
      <div class="discover-cards">
        <div class="discover-card">
          <img src="https://oberonmall.com/wp-content/uploads/2024/12/promo_spot_20241114152108.gif" alt="Win A Spree" width="310" height="310" loading="lazy" />
          <div class="discover-card-overlay"><h3>Win A Spree</h3></div>
        </div>
        <div class="discover-card">
          <img src="https://oberonmall.com/wp-content/uploads/2024/12/Prussia_Eatly_Spot3m_20241105103103.jpg" alt="Gourmet Delight" width="310" height="310" loading="lazy" />
          <div class="discover-card-overlay"><h3>Gourmet Delight</h3></div>
        </div>
        <div class="discover-card">
          <img src="https://oberonmall.com/wp-content/uploads/2024/12/freepik__candid-image-photography-natural-textures-highly-r__26435.jpeg" alt="Time For Santa" width="310" height="310" loading="lazy" />
          <div class="discover-card-overlay"><h3>Time For Santa</h3></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MAKE YOURSELF GORGEOUS AND SHINE ===== -->
  <section class="section">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <span class="eyebrow">About</span>
          <h2>Make Yourself Gorgeous And Shine</h2>
          <p>Oberon Mall is Kerala's first lifestyle shopping mall, a destination where shopping meets entertainment. With over 60 premium brands, diverse dining options, and a world-class cinema, every visit is a new discovery.</p>
          <a href="/about/" class="btn">About Oberon Mall</a>
        </div>
        <div class="about-images">
          <img src="https://oberonmall.com/wp-content/uploads/2024/12/FINAL-RENDER-2.png" alt="Oberon Mall Interior" width="520" height="500" loading="lazy" class="about-img-large" />
          <img src="https://oberonmall.com/wp-content/uploads/2024/12/Girl-model-e1733227249545.png" alt="Oberon Mall Model" width="250" height="313" loading="lazy" class="about-img-model" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HAPPINESS IN RETURN MARQUEE ===== -->
  <section class="happiness-marquee" aria-label="Happiness in Return">
    <div class="happiness-marquee-track">
      {[0,1,2,3,4,5,6,7].map(() => (
        <img src="https://oberonmall.com/wp-content/uploads/2024/12/Happiness-in-return-White.png" alt="Happiness in Return" width="244" height="30" loading="lazy" />
      ))}
    </div>
  </section>

  <!-- ===== IT'S POPCORN TIME ===== -->
  <section class="popcorn-section">
    <div class="container">
      <div class="popcorn-grid">
        <div class="popcorn-text">
          <span class="eyebrow eyebrow--gold">Entertainment</span>
          <h2>It's Popcorn Time</h2>
          <h3>Big Screen Magic Awaits</h3>
          <p>Experience the thrill of the big screen at Oberon Mall's premium cinema. Latest releases, comfortable seating, and unforgettable moments.</p>
          <a href="/movies/" class="btn btn-outline-gold">Explore</a>
        </div>
        <div class="popcorn-image">
          <img src="https://oberonmall.com/wp-content/uploads/2024/12/model-2.png" alt="Movies at Oberon Mall" width="480" height="600" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== EXPLORE TRENDS BUTTON ===== -->
  <section class="section section--center">
    <div class="container">
      <a href="/brand/" class="btn btn-large">Explore Trends</a>
    </div>
  </section>

  <!-- ===== BRANDS YOU LOVE ===== -->
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">Shopping</span>
        <h2>Brands You Love</h2>
        <p class="section-sub">Discover premium brands under one roof.</p>
      </div>
      <div class="brands-grid">
        <div class="brand-image-large">
          <img src="https://oberonmall.com/wp-content/uploads/2024/12/Oberon-L.jpg" alt="Oberon Mall Brands" loading="lazy" />
          <div class="brand-image-overlay">
            <h3>BASICS MEGA SALE</h3>
          </div>
        </div>
        <div class="brand-image-square">
          <img src="https://oberonmall.com/wp-content/uploads/2024/12/Oberon-Sqr.jpg" alt="Oberon Mall Brands" width="1080" height="1080" loading="lazy" />
          <div class="brand-image-overlay">
            <h3>BASICS MEGA SALE</h3>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FEATURED DEALS ===== -->
  <section class="section section--cream">
    <div class="container">
      <h3 class="deals-title">Featured Deals</h3>
      <div class="deals-grid">
        <div class="deal-card">
          <img src="https://oberonmall.com/wp-content/uploads/2024/12/Untitled-design-12.png" alt="BASICS MEGA SALE" width="320" height="200" loading="lazy" />
          <div class="deal-card-body">
            <h4>BASICS MEGA SALE</h4>
          </div>
        </div>
        <div class="deal-card">
          <img src="https://oberonmall.com/wp-content/uploads/2024/12/PizzaHut-1.jpg" alt="NOW OPEN: PIZZA HUT" width="320" height="200" loading="lazy" />
          <div class="deal-card-body">
            <h4>NOW OPEN: PIZZA HUT</h4>
          </div>
        </div>
        <div class="deal-card">
          <img src="https://oberonmall.com/wp-content/uploads/2024/12/Untitled-design-13.png" alt="TITAN" width="320" height="200" loading="lazy" />
          <div class="deal-card-body">
            <h4>TITAN</h4>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHAT'S HAPPENING AT OBERON MALL? ===== -->
  <section class="happening-section">
    <div class="container">
      <div class="happening-grid">
        <div class="happening-image">
          <img src="https://oberonmall.com/wp-content/uploads/2024/12/O-All-P.png" alt="What's Happening at Oberon Mall" width="550" height="550" loading="lazy" />
        </div>
        <div class="happening-text">
          <span class="eyebrow eyebrow--gold">Events</span>
          <h2>What's Happening at Oberon Mall?</h2>
          <p>Stay up to date with the latest events, promotions, and activities at Oberon Mall. There's always something exciting happening!</p>
          <a href="/events/" class="btn btn-outline-gold">Explore Events</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== NEWS & ARTICLES ===== -->
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">Latest</span>
        <h2>News &amp; Articles</h2>
        <p class="section-sub">Keeping you up-to-date with the latest news and events.</p>
      </div>
      <div class="news-grid">
        {newsArticles.map((article, i) => (
          <article class="news-card">
            <a href={`/news/${article.slug}/`} class="news-card-link">
              <img src={newsImages[i]} alt={article.title} loading="lazy" />
              <div class="news-card-body">
                <div class="news-card-date">{article.date}</div>
                <h3>{article.title}</h3>
                <span class="read-more">Read More →</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FOOTER GIF ===== -->
  <div class="footer-gif">
    <img src="https://oberonmall.com/wp-content/uploads/2024/12/Oberon-gif-Video.gif" alt="Oberon Mall" width="1265" height="114" loading="lazy" />
  </div>

  <!-- ===== NEWSLETTER ===== -->
  <Newsletter />
</Layout>