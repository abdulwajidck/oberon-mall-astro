---
import Layout from '../layouts/Layout.astro';
import Newsletter from '../components/Newsletter.astro';
---

<Layout title="Events - Oberon Mall" description="Discover exciting events at Oberon Mall. From live concerts to seasonal celebrations, there's always something happening.">
  <!-- 1. Page Hero -->
  <section class="page-hero">
    <h1>Discover Exciting Events</h1>
  </section>

  <section class="section">
    <div class="container">
      <!-- 2. Search bar + view toggles + date navigation -->
      <div class="events-toolbar">
        <div class="events-search">
          <input type="search" placeholder="Search Events..." aria-label="Search events" />
        </div>
        <div class="events-view-toggle">
          <button class="active" data-view="list">List</button>
          <button data-view="month">Month</button>
          <button data-view="day">Day</button>
        </div>
        <div class="events-date-nav">
          <button aria-label="Previous date">‹</button>
          <span>December 2024</span>
          <button aria-label="Next date">›</button>
        </div>
      </div>

      <!-- 3. Latest Past Events heading -->
      <div class="section-heading" style="text-align:left;margin-bottom:30px;">
        <h2 style="font-size:1.8rem;">Latest Past Events</h2>
      </div>

      <!-- 4. Event card: Sooraj Santosh Live Concert -->
      <div style="max-width:700px;">
        <div class="event-card">
          <div class="event-date">Past Event</div>
          <h3>Sooraj Santosh Live Concert</h3>
          <p style="color:#737373;margin:12px 0;line-height:1.7;">Experience the magic of live music at Oberon Mall with Sooraj Santosh, one of Kerala's most beloved playback singers. An unforgettable evening of melody and entertainment that captivated audiences of all ages.</p>
          <a href="#" class="read-more">View Details →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Newsletter -->
  <Newsletter />
</Layout>

<script>
  const toggleButtons = document.querySelectorAll('.events-view-toggle button');
  toggleButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      toggleButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });
</script>